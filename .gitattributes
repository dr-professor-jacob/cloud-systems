# Force LF line endings for everything deployed to Linux
* text=auto eol=lf

# Explicitly LF for all config/code/template files
*.yml      text eol=lf
*.yaml     text eol=lf
*.py       text eol=lf
*.sh       text eol=lf
*.j2       text eol=lf
*.conf     text eol=lf
*.ini      text eol=lf
*.json     text eol=lf
*.tf       text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.js       text eol=lf

# Binary files - never touch line endings
*.png      binary
*.jpg      binary
*.ico      binary
