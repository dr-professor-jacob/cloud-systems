<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cloud Systems — Azure IaC Project</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Segoe UI", system-ui, sans-serif;
      background: #eef2f7;
      color: #1a1a1a;
      min-height: 100vh;
    }

    /* ── Header ── */
    header {
      background: linear-gradient(135deg, #005ea2 0%, #0078d4 100%);
      color: #fff;
      padding: 1.1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .hd-left { display: flex; align-items: center; gap: .9rem; flex-wrap: wrap; }
    .hd-title { font-size: 1.05rem; font-weight: 600; letter-spacing: .04em; }
    .hd-sub { font-size: .72rem; opacity: .75; margin-top: .1rem; }

    .status-pill {
      display: flex; align-items: center; gap: .4rem;
      font-size: .68rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 99px;
      padding: .22rem .75rem;
    }
    .status-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #57ff57;
      box-shadow: 0 0 7px #57ff57;
      animation: blink 2.5s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    .hd-clocks {
      text-align: right;
      font-size: .8rem;
      display: flex; flex-direction: column; gap: .1rem;
      font-variant-numeric: tabular-nums;
      opacity: .9;
      white-space: nowrap;
    }
    #clock-local { opacity: .65; font-size: .72rem; }

    /* ── Layout ── */
    main {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.5rem 3rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    .row.thirds {
      grid-template-columns: 1fr 1fr 1fr;
    }
    @media (max-width: 760px) {
      .row, .row.thirds { grid-template-columns: 1fr; }
    }

    /* ── Cards ── */
    .card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.06);
      padding: 1.4rem 1.5rem;
    }
    .card-title {
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #0078d4;
      margin-bottom: .9rem;
      padding-bottom: .6rem;
      border-bottom: 1px solid #f0f0f0;
    }

    /* ── Stat strip ── */
    .stat-row {
      display: flex; flex-wrap: wrap; gap: 1rem;
    }
    .stat {
      flex: 1; min-width: 90px;
      background: #f4f8fd;
      border-radius: 8px;
      padding: .7rem 1rem;
      text-align: center;
    }
    .stat-num { font-size: 1.6rem; font-weight: 700; color: #0078d4; line-height: 1; }
    .stat-label { font-size: .68rem; color: #706e6c; margin-top: .25rem; text-transform: uppercase; letter-spacing: .05em; }

    /* ── Tables ── */
    .infra-table, .vis-table { width: 100%; border-collapse: collapse; }
    .infra-table tr.data, .vis-table tr { border-bottom: 1px solid #f2f2f2; }
    .infra-table tr.data:last-child, .vis-table tr:last-child { border-bottom: none; }
    .infra-table tr.data:hover td, .vis-table tr:hover td { background: #f4f8fd; }
    .infra-table td, .vis-table td { padding: .52rem .3rem; font-size: .86rem; vertical-align: top; transition: background .12s; }
    .infra-table td:first-child, .vis-table td:first-child { color: #706e6c; width: 44%; }
    .infra-table td:last-child, .vis-table td:last-child { color: #1a1a1a; font-weight: 500; }
    .infra-table tr.section-row td {
      font-size: .65rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #0078d4;
      padding-top: 1.1rem; padding-bottom: .3rem;
    }
    .infra-table tr.section-row:first-child td { padding-top: .1rem; }

    /* ── Bullet lists ── */
    .bullets { list-style: none; display: flex; flex-direction: column; gap: .7rem; }
    .bullets li {
      font-size: .865rem; color: #333; line-height: 1.55;
      padding-left: 1.15rem; position: relative;
    }
    .bullets li::before { content: "→"; position: absolute; left: 0; color: #0078d4; font-weight: 700; }
    .bullets li strong { color: #1a1a1a; }

    /* ── Timeline ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-item {
      display: grid;
      grid-template-columns: 3.5rem 1fr;
      gap: 0 1rem;
      position: relative;
    }
    .tl-item:not(:last-child) .tl-line { display: block; }
    .tl-badge-col {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .tl-badge {
      width: 2rem; height: 2rem;
      border-radius: 50%;
      background: #0078d4;
      color: #fff;
      font-size: .7rem;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      z-index: 1;
    }
    .tl-line {
      width: 2px;
      flex: 1;
      background: #dde8f5;
      margin: .25rem 0;
      min-height: .75rem;
    }
    .tl-body { padding-bottom: 1.1rem; }
    .tl-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: #0078d4; }
    .tl-title { font-size: .9rem; font-weight: 600; color: #1a1a1a; margin: .15rem 0 .3rem; }
    .tl-desc { font-size: .82rem; color: #444; line-height: 1.5; }
    .tl-item:last-child .tl-body { padding-bottom: 0; }

    /* ── Tag chips ── */
    .tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .75rem; }
    .tag {
      font-size: .68rem; font-weight: 600; letter-spacing: .04em;
      background: #e8f1fb; color: #005ea2;
      border-radius: 99px;
      padding: .2rem .6rem;
    }

    /* ── Mono ── */
    .mono { font-family: "Cascadia Code", "Fira Code", "Courier New", monospace; font-size: .77rem; word-break: break-all; }
    code {
      font-family: "Cascadia Code", "Fira Code", "Courier New", monospace;
      font-size: .82em;
      background: #f0f4fa;
      padding: .1em .35em;
      border-radius: 4px;
      color: #005ea2;
    }

    /* ── Code blocks ── */
    .code-section { display: flex; flex-direction: column; gap: 1.1rem; }
    .code-block { background: #0d1117; border-radius: 8px; overflow: hidden; }
    .code-label {
      font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      color: #7d8590; background: #161b22; padding: .4rem .9rem;
      border-bottom: 1px solid #21262d;
    }
    .code-block pre {
      margin: 0; padding: .9rem 1rem;
      font-family: "Cascadia Code", "Fira Code", "Courier New", monospace;
      font-size: .78rem; line-height: 1.6;
      color: #e6edf3; overflow-x: auto;
    }
    .c  { color: #8b949e; }  /* comment */
    .k  { color: #ff7b72; }  /* keyword */
    .s  { color: #a5d6ff; }  /* string */
    .v  { color: #79c0ff; }  /* variable/resource name */
    .f  { color: #d2a8ff; }  /* function/block */
    .n  { color: #ffa657; }  /* number/value */

    /* ── Note box ── */
    .note {
      background: #f4f8fd;
      border-left: 3px solid #0078d4;
      border-radius: 0 6px 6px 0;
      padding: .6rem .9rem;
      font-size: .82rem;
      color: #444;
      line-height: 1.5;
      margin-top: .9rem;
    }
  </style>
</head>
<body>
  <header>
    <div class="hd-left">
      <div>
        <div class="hd-title">Cloud Systems — Azure IaC Deployment</div>
        <div class="hd-sub">ITS 5760 &nbsp;·&nbsp; Spring 2026 &nbsp;·&nbsp; {{ app_domain }}</div>
      </div>
      <div class="status-pill"><span class="status-dot"></span>Operational</div>
    </div>
    <div class="hd-clocks">
      <span id="clock-utc">UTC —:—:—</span>
      <span id="clock-local"></span>
    </div>
  </header>

  <main>

    <!-- Overview -->
    <div class="card">
      <div class="card-title">Project Overview</div>
      <p style="font-size:.875rem;color:#333;line-height:1.6;margin-bottom:.9rem;">
        Two-VM deployment on Azure, built entirely with <strong>OpenTofu</strong> and <strong>Ansible</strong>.
        <code>tofu apply</code> provisions the network, VMs, Key Vault, and monitoring.
        <code>ansible-playbook</code> installs and configures everything on both machines.
        No manual steps at any point.
      </p>
    </div>

    <!-- Infra table + Security -->
    <div class="row">

      <div class="card">
        <div class="card-title">Infrastructure</div>
        <table class="infra-table">
          <tr class="section-row"><td colspan="2">Host</td></tr>
          <tr class="data"><td>Domain</td><td>{{ app_domain }}</td></tr>
          <tr class="data"><td>Region</td><td>Azure South Central US</td></tr>
          <tr class="data"><td>Protocol</td><td>HTTP/2 · TLS 1.2 / 1.3</td></tr>
          <tr class="data"><td>Certificate</td><td>Let's Encrypt (auto-renew)</td></tr>

          <tr class="section-row"><td colspan="2">Virtual Machines</td></tr>
          <tr class="data"><td>App VM</td><td>Standard_B2pts_v2 · ARM64</td></tr>
          <tr class="data"><td>DB VM</td><td>Standard_B2pts_v2 · ARM64</td></tr>
          <tr class="data"><td>OS</td><td>Ubuntu 24.04 LTS (arm64)</td></tr>
          <tr class="data"><td>Auth</td><td>SSH key only, no passwords</td></tr>

          <tr class="section-row"><td colspan="2">Network</td></tr>
          <tr class="data"><td>VNet</td><td>10.0.0.0/16</td></tr>
          <tr class="data"><td>App subnet</td><td>10.0.1.0/24 (public IP)</td></tr>
          <tr class="data"><td>DB subnet</td><td>10.0.2.0/24 (no public IP)</td></tr>
          <tr class="data"><td>DB port 3306</td><td>App subnet only (NSG rule)</td></tr>
          <tr class="data"><td>DB SSH</td><td>App subnet only (bastion pattern)</td></tr>

          <tr class="section-row"><td colspan="2">Automation Stack</td></tr>
          <tr class="data"><td>Provisioning</td><td>OpenTofu</td></tr>
          <tr class="data"><td>Configuration</td><td>Ansible</td></tr>
          <tr class="data"><td>Secret encryption</td><td>Ansible Vault</td></tr>
          <tr class="data"><td>Vault password</td><td>Azure Key Vault (runtime fetch)</td></tr>
          <tr class="data"><td>OpenTofu state</td><td>Azure Blob Storage (shared, locked)</td></tr>
          <tr class="data"><td>Monitoring</td><td>Azure Monitor + email alerts</td></tr>
          <tr class="data"><td>AI interface</td><td>MCP over SSE</td></tr>
        </table>
      </div>

      <div class="card">
        <div class="card-title">Security Hardening</div>
        <ul class="bullets">
          <li><strong>SSH key-only auth.</strong> Password auth is disabled. The DB VM has no public IP, so reaching it requires tunneling through the app VM.</li>
          <li><strong>fail2ban</strong> runs on both VMs. 5 failed SSH attempts in 10 minutes gets the source IP banned for an hour.</li>
          <li><strong>Unattended-upgrades</strong> pulls security patches automatically from the Ubuntu security repo on both machines.</li>
          <li><strong>MariaDB hardened at deploy time:</strong> anonymous users removed, test database dropped, remote root disabled. Same steps as <code>mysql_secure_installation</code>, scripted through Ansible.</li>
          <li><strong>MariaDB bound to the DB subnet interface</strong>, so it does not accept connections on the app-facing NIC even within the VNet.</li>
          <li><strong>DB NSG allows port 3306 from <code>10.0.1.0/24</code> only.</strong> Combined with no public IP on the DB VM, there is no network path from the internet to the database.</li>
          <li><strong>Ansible Vault</strong> encrypts secrets at rest. The decryption password lives in Azure Key Vault and is fetched at runtime by <code>vault_pass.sh</code>, so it never sits on disk locally.</li>
          <li><strong>Azure Monitor</strong> sends an email alert if CPU stays above 85% for 5 minutes.</li>
        </ul>
        <div class="note">
          The DB is blocked at two independent layers: the NSG drops anything that isn't from the app subnet, and MariaDB's bind-address means it isn't even listening on other interfaces. Either one alone would be sufficient; both together means there's no single point of misconfiguration that exposes the database.
        </div>
      </div>

    </div>

    <!-- Development iterations -->
    <div class="card">
      <div class="card-title">Development — How It Evolved</div>
      <div class="timeline">

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">1</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 1</div>
            <div class="tl-title">Terraform + Ansible scaffolding: single VM, HTTP only</div>
            <div class="tl-desc">
              One VM, one subnet, no TLS. Terraform provisions the VM and public IP; Ansible installs nginx and drops a static page.
              The goal was getting the IaC pipeline working end-to-end before adding anything else.
              Manually SSHing in to make changes was the baseline to beat.
            </div>
            <div class="tags"><span class="tag">Terraform</span><span class="tag">Ansible</span><span class="tag">nginx</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">2</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 2</div>
            <div class="tl-title">Two-tier network: app and DB on separate subnets, MariaDB</div>
            <div class="tl-desc">
              Split into two VMs across two subnets. The DB VM gets no public IP; only the app subnet can reach port 3306.
              Ansible now runs two playbooks, one per host group. Terraform's <code>local_file</code> resource
              writes the live public IP into Ansible's inventory on every apply, so the playbook always targets the right host
              without any manual edits.
            </div>
            <div class="tags"><span class="tag">Two-tier</span><span class="tag">NSG</span><span class="tag">MariaDB</span><span class="tag">Inventory automation</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">3</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 3</div>
            <div class="tl-title">TLS + secrets: Let's Encrypt, Ansible Vault, remote state</div>
            <div class="tl-desc">
              certbot has a chicken-and-egg issue: nginx needs to serve port 80 to complete the ACME challenge,
              but the final nginx config references a cert that doesn't exist yet. Fixed by deploying an HTTP-only config first
              (<code>when: not cert_stat.stat.exists</code>), running certbot, then swapping in the SSL config.
              Secrets moved into Ansible Vault. Terraform state moved to Azure Blob Storage so it stays off local machines.
              Used <code>nip.io</code> to get a real domain from the static IP without buying one.
            </div>
            <div class="tags"><span class="tag">Let's Encrypt</span><span class="tag">Ansible Vault</span><span class="tag">Azure Blob</span><span class="tag">nip.io</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">4</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 4</div>
            <div class="tl-title">Hardening: fail2ban, unattended-upgrades, MariaDB lockdown, ARM64</div>
            <div class="tl-desc">
              Added fail2ban for SSH brute-force protection, unattended-upgrades for automated patching, and MariaDB hardening
              through Ansible's <code>mysql_user</code> / <code>mysql_db</code> modules. Also switched from Standard_B2s (x86) to
              <strong>Standard_B2pts_v2</strong> (Ampere ARM64): same performance tier, cheaper, and Ubuntu 24.04 supports ARM64 well.
              All tasks are idempotent, so re-running on an already-configured server changes nothing.
            </div>
            <div class="tags"><span class="tag">fail2ban</span><span class="tag">Unattended-upgrades</span><span class="tag">ARM64</span><span class="tag">MariaDB hardening</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">5</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 5</div>
            <div class="tl-title">Azure Key Vault: no local vault password needed</div>
            <div class="tl-desc">
              Before this, decrypting Ansible Vault meant either typing the password or storing it in a file.
              Replaced with <code>vault_pass.sh</code>, a script that calls <code>az keyvault secret show</code> and prints the password to stdout.
              Ansible's <code>--vault-password-file</code> accepts any executable, so it just calls the script at runtime.
              The password only ever lives in Azure Key Vault. Terraform provisions the vault as part of the same apply.
            </div>
            <div class="tags"><span class="tag">Azure Key Vault</span><span class="tag">RBAC</span><span class="tag">Passwordless</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">6</div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 6</div>
            <div class="tl-title">MCP servers + Azure Monitor: live infrastructure access and alerting</div>
            <div class="tl-desc">
              Added two <strong>Model Context Protocol (MCP)</strong> servers: one on the app VM for infrastructure metrics,
              one on the DB VM for database queries. Both run as systemd services (Python/FastMCP + uvicorn),
              proxied through nginx over SSE. Claude Code connects to this deployment directly through the
              <em>cloud-infra</em> MCP server and can query live system state.
              Also added Azure Monitor alerts: CPU above 85% for 5 minutes sends an email.
            </div>
            <div class="tags"><span class="tag">MCP / SSE</span><span class="tag">FastMCP</span><span class="tag">systemd</span><span class="tag">Azure Monitor</span><span class="tag">Action Groups</span></div>
          </div>
        </div>

      </div>
    </div>

    <!-- MCP + Visitor -->
    <div class="row">

      <div class="card">
        <div class="card-title">MCP Interface</div>
        <p style="font-size:.875rem;color:#333;line-height:1.6;margin-bottom:.9rem;">
          MCP (Model Context Protocol) is an open standard that lets AI assistants call structured tools on a remote server — like an API, but designed for LLMs. This deployment runs two MCP servers:
        </p>
        <ul class="bullets">
          <li><strong>mcp-infra</strong> (this VM) — read-only tools: live system metrics and nginx stats. Public SSE endpoint below.</li>
          <li><strong>mcp-db</strong> (DB VM) — database query tools. Private: only reachable through the app VM since the DB has no public IP.</li>
        </ul>
        <div class="note" style="margin-top:.9rem;">
          Both run as systemd services (Python / FastMCP + uvicorn), proxied through nginx over SSE. Claude Code connects directly and calls tools in real time — the metrics on this page are written by Claude via MCP.
        </div>
        <div class="tags" style="margin-top:.9rem;">
          <span class="tag">MCP / SSE</span>
          <span class="tag">FastMCP</span>
          <span class="tag">uvicorn</span>
          <span class="tag">nginx proxy</span>
          <span class="tag">systemd</span>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Your Connection</div>
        <table class="vis-table">
          <tr><td>Browser</td><td id="v-browser"></td></tr>
          <tr><td>OS</td><td id="v-os"></td></tr>
          <tr><td>Language</td><td id="v-lang"></td></tr>
          <tr><td>Screen</td><td id="v-screen"></td></tr>
          <tr><td>CPU threads</td><td id="v-cpu"></td></tr>
          <tr><td>Cookies</td><td id="v-cookies"></td></tr>
          <tr><td>Page load</td><td id="v-load"></td></tr>
          <tr><td>User agent</td><td id="v-ua" class="mono"></td></tr>
        </table>
      </div>

    </div>

    <!-- MCP tools + activity -->
    <div class="row">

      <div class="card">
        <div class="card-title">Available MCP Tools</div>
        <table class="vis-table">
          <tr><td><code>system_info</code></td><td>Uptime, load averages (1m/5m/15m), memory, and disk usage</td></tr>
          <tr><td><code>nginx_stats</code></td><td>Active connections and request counts from nginx stub_status</td></tr>
          <tr><td><code>write_activity</code></td><td>Claude logs a summary of each session — displayed in the card to the right</td></tr>
        </table>
        <div class="note" style="margin-top:.9rem;">
          Want to try it? Add this to your <code>~/.claude/mcp.json</code> (or <code>.mcp.json</code> in any project):
        </div>
        <div class="code-block" style="margin-top:.75rem;">
          <div class="code-label">Connect with Claude Code</div>
          <pre>{
  <span class="s">"mcpServers"</span>: {
    <span class="s">"cloud-infra"</span>: {
      <span class="s">"type"</span>: <span class="s">"streamable-http"</span>,
      <span class="s">"url"</span>:  <span class="s">"https://{{ app_domain }}/mcp/"</span>
    }
  }
}</pre>
        </div>
      </div>

      <div class="card">
        <div class="card-title" style="display:flex;align-items:center;justify-content:space-between;">
          <span>Last Claude Session</span>
          <span id="activity-age" style="font-size:.68rem;font-weight:400;text-transform:none;letter-spacing:0;color:#706e6c;"></span>
        </div>
        <table class="vis-table" style="margin-bottom:.9rem;">
          <tr><td>When</td><td id="a-updated">—</td></tr>
          <tr><td>Tools used</td><td id="a-calls">—</td></tr>
        </table>
        <p id="a-summary" style="font-size:.875rem;color:#333;line-height:1.6;font-style:italic;">—</p>
        <div class="note" id="activity-note" style="display:none;"></div>

        <div style="margin-top:1.2rem;border-top:1px solid #e8e5e1;padding-top:1.1rem;">
          <div style="font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:#706e6c;margin-bottom:.6rem;">Ask Claude a Question</div>
          <form id="ask-form">
            <textarea id="ask-input" maxlength="300" rows="2"
              placeholder="Ask anything about this project…"
              style="width:100%;box-sizing:border-box;font-family:inherit;font-size:.875rem;border:1px solid #d4d0cb;border-radius:4px;padding:.5rem .65rem;resize:vertical;color:#222;background:#faf9f7;"></textarea>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:.45rem;">
              <span id="ask-counter" style="font-size:.72rem;color:#888;">300 characters remaining</span>
              <button id="ask-btn" type="submit"
                style="font-size:.82rem;padding:.38rem .9rem;background:#1a56db;color:#fff;border:none;border-radius:4px;cursor:pointer;font-weight:500;">Ask</button>
            </div>
          </form>
          <div id="ask-answer" style="display:none;margin-top:.8rem;background:#f0f4ff;border-left:3px solid #1a56db;padding:.6rem .8rem;border-radius:0 4px 4px 0;">
            <p id="ask-answer-text" style="margin:0;font-size:.875rem;color:#1a1a2e;line-height:1.6;"></p>
          </div>
          <div id="ask-error" style="display:none;margin-top:.6rem;font-size:.82rem;color:#c0392b;"></div>
          <div id="ask-remaining" style="display:none;margin-top:.4rem;font-size:.72rem;color:#888;"></div>
        </div>
      </div>

    </div>

    <!-- Live metrics -->
    <div class="card" id="metrics-card">
      <div class="card-title" style="display:flex;align-items:center;justify-content:space-between;">
        <span>Live Server Metrics</span>
        <span id="metrics-age" style="font-size:.68rem;font-weight:400;text-transform:none;letter-spacing:0;color:#706e6c;"></span>
      </div>
      <div class="row thirds" id="metrics-stats">
        <div class="stat"><div class="stat-num" id="m-load">—</div><div class="stat-label">Load (1m)</div></div>
        <div class="stat"><div class="stat-num" id="m-mem">—</div><div class="stat-label">Memory Used</div></div>
        <div class="stat"><div class="stat-num" id="m-disk">—</div><div class="stat-label">Disk Used</div></div>
      </div>
      <table class="vis-table" style="margin-top:1rem;">
        <tr><td>Uptime</td><td id="m-uptime">—</td></tr>
        <tr><td>Load avg (1m / 5m / 15m)</td><td id="m-loadfull">—</td></tr>
        <tr><td>Memory</td><td id="m-memfull">—</td></tr>
        <tr><td>Disk</td><td id="m-diskfull">—</td></tr>
        <tr><td>Nginx connections</td><td id="m-nginx">—</td></tr>
        <tr><td>Last updated by Claude</td><td id="m-updated">—</td></tr>
      </table>
      <div class="note" id="metrics-note" style="display:none;"></div>
    </div>

    <!-- Commands -->
    <div class="card">
      <div class="card-title">Deployment — Two Commands</div>
      <div class="code-section">
        <div class="code-block">
          <div class="code-label">1 — Provision infrastructure (OpenTofu)</div>
          <pre><span class="c"># Creates VNet, subnets, NSGs, VMs, Key Vault, Monitor alerts,</span>
<span class="c"># and writes inventory.ini + group_vars with the live public IP.</span>
tofu apply -auto-approve</pre>
        </div>
        <div class="code-block">
          <div class="code-label">2 — Configure everything (Ansible)</div>
          <pre><span class="c"># Installs and hardens both VMs: nginx, TLS, fail2ban,</span>
<span class="c"># unattended-upgrades, MariaDB, MCP servers — all idempotent.</span>
<span class="c"># Vault password fetched from Azure Key Vault at runtime (vault_pass.sh).</span>
ansible-playbook setup_app.yml setup_db.yml -i inventory.ini</pre>
        </div>
      </div>
    </div>

    <!-- Config highlights -->
    <div class="row">

      <div class="card">
        <div class="card-title">OpenTofu — Key Blocks</div>
        <div class="code-section">

          <div class="code-block">
            <div class="code-label">NSG: DB only reachable from app subnet</div>
            <pre><span class="f">resource</span> <span class="s">"azurerm_network_security_group"</span> <span class="v">"db_nsg"</span> {
  <span class="c"># No public IP on DB VM + NSG = two independent</span>
  <span class="c"># enforcement layers blocking internet access.</span>

  <span class="f">security_rule</span> {
    name                  = <span class="s">"AllowMySQL"</span>
    priority              = <span class="n">100</span>
    direction             = <span class="s">"Inbound"</span>
    access                = <span class="s">"Allow"</span>
    destination_port      = <span class="s">"3306"</span>
    <span class="c"># app subnet only; nothing else can reach MariaDB</span>
    source_address_prefix = <span class="s">"10.0.1.0/24"</span>
  }
}</pre>
          </div>

          <div class="code-block">
            <div class="code-label">Key Vault — Ansible Vault password at rest</div>
            <pre><span class="f">resource</span> <span class="s">"azurerm_key_vault"</span> <span class="v">"kv"</span> {
  name      = <span class="s">"cloud-v3-kv"</span>
  tenant_id = <span class="f">data.azurerm_client_config.current</span>.tenant_id
  sku_name  = <span class="s">"standard"</span>
  <span class="c"># Vault password stored here; fetched at runtime</span>
  <span class="c"># by vault_pass.sh; never touches disk locally.</span>
}

<span class="c"># Terraform writes the live IP into Ansible's inventory</span>
<span class="c"># on every apply; no manual IP hunting after redeploy.</span>
<span class="f">resource</span> <span class="s">"local_file"</span> <span class="v">"ansible_vars"</span> {
  content  = <span class="s">"app_domain: \"</span><span class="n">${azurerm_public_ip.app_pip.ip_address}</span><span class="s">.nip.io\""</span>
  filename = <span class="s">"group_vars/all/terraform_outputs.yml"</span>
}</pre>
          </div>

        </div>
      </div>

      <div class="card">
        <div class="card-title">Ansible — Key Tasks</div>
        <div class="code-section">

          <div class="code-block">
            <div class="code-label">Certbot — HTTP config first, then TLS</div>
            <pre><span class="c"># Chicken-and-egg: certbot needs port 80 open to</span>
<span class="c"># validate the domain, but the final nginx config</span>
<span class="c"># references the cert that doesn't exist yet.</span>
- <span class="k">name</span>: Deploy HTTP-only nginx config
  <span class="k">template</span>:
    src: nginx.conf.j2
    dest: /etc/nginx/nginx.conf
  <span class="k">when</span>: not cert_stat.stat.exists  <span class="c"># skip if cert already exists</span>

- <span class="k">name</span>: Obtain SSL certificate
  <span class="k">command</span>: >
    certbot certonly --webroot -w /var/www/html
    -d {% raw %}{{ app_domain }}{% endraw %} --non-interactive
  args:
    creates: /etc/letsencrypt/live/{% raw %}{{ app_domain }}{% endraw %}/fullchain.pem

- <span class="k">name</span>: Deploy HTTPS nginx config  <span class="c"># now the cert exists</span>
  <span class="k">template</span>:
    src: nginx_ssl.conf.j2
    dest: /etc/nginx/nginx.conf</pre>
          </div>

          <div class="code-block">
            <div class="code-label">MariaDB hardening (scripted secure_installation)</div>
            <pre"><span class="c"># Equivalent to running mysql_secure_installation,</span>
<span class="c"># but fully automated and idempotent.</span>
- <span class="k">name</span>: Remove anonymous users
  <span class="k">mysql_user</span>:
    name: <span class="s">''</span>
    host_all: yes
    state: absent

- <span class="k">name</span>: Disallow remote root login
  <span class="k">mysql_user</span>:
    name: root
    host: <span class="s">'%'</span>
    state: absent

- <span class="k">name</span>: Bind MariaDB to internal subnet only
  <span class="k">copy</span>:
    dest: /etc/mysql/mariadb.conf.d/99-bind.cnf
    content: |
      [mysqld]
      bind-address = {% raw %}{{ db_bind_address }}{% endraw %}</pre>
          </div>

        </div>
      </div>

    </div>

  </main>

  <script src="/session.js"></script>
  <script src="/metrics.js"></script>
  <script src="/ask.js"></script>
</body>
</html>
