<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cloud Systems — Azure IaC Project</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Segoe UI", system-ui, sans-serif;
      background: #eef2f7;
      color: #1a1a1a;
      min-height: 100vh;
    }

    /* ── Header ── */
    header {
      background: linear-gradient(135deg, #005ea2 0%, #0078d4 100%);
      color: #fff;
      padding: 1.1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .hd-left { display: flex; align-items: center; gap: .9rem; flex-wrap: wrap; }
    .hd-title { font-size: 1.05rem; font-weight: 600; letter-spacing: .04em; }
    .hd-sub { font-size: .72rem; opacity: .75; margin-top: .1rem; }

    .status-pill {
      display: flex; align-items: center; gap: .4rem;
      font-size: .68rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 99px;
      padding: .22rem .75rem;
    }
    .status-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #57ff57;
      box-shadow: 0 0 7px #57ff57;
      animation: blink 2.5s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    .hd-clocks {
      text-align: right;
      font-size: .8rem;
      display: flex; flex-direction: column; gap: .1rem;
      font-variant-numeric: tabular-nums;
      opacity: .9;
      white-space: nowrap;
    }
    #clock-local { opacity: .65; font-size: .72rem; }

    /* ── Layout ── */
    main {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1.5rem 3rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    .row.thirds {
      grid-template-columns: 1fr 1fr 1fr;
    }
    @media (max-width: 760px) {
      .row, .row.thirds { grid-template-columns: 1fr; }
    }

    /* ── Cards ── */
    .card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.06);
      padding: 1.4rem 1.5rem;
    }
    .card-title {
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #0078d4;
      margin-bottom: .9rem;
      padding-bottom: .6rem;
      border-bottom: 1px solid #f0f0f0;
    }

    /* ── Stat strip ── */
    .stat-row {
      display: flex; flex-wrap: wrap; gap: 1rem;
    }
    .stat {
      flex: 1; min-width: 90px;
      background: #f4f8fd;
      border-radius: 8px;
      padding: .7rem 1rem;
      text-align: center;
    }
    .stat-num { font-size: 1.6rem; font-weight: 700; color: #0078d4; line-height: 1; }
    .stat-label { font-size: .68rem; color: #706e6c; margin-top: .25rem; text-transform: uppercase; letter-spacing: .05em; }

    /* ── Tables ── */
    .infra-table, .vis-table { width: 100%; border-collapse: collapse; }
    .infra-table tr.data, .vis-table tr { border-bottom: 1px solid #f2f2f2; }
    .infra-table tr.data:last-child, .vis-table tr:last-child { border-bottom: none; }
    .infra-table tr.data:hover td, .vis-table tr:hover td { background: #f4f8fd; }
    .infra-table td, .vis-table td { padding: .52rem .3rem; font-size: .86rem; vertical-align: top; transition: background .12s; }
    .infra-table td:first-child, .vis-table td:first-child { color: #706e6c; width: 44%; }
    .infra-table td:last-child, .vis-table td:last-child { color: #1a1a1a; font-weight: 500; }
    .infra-table tr.section-row td {
      font-size: .65rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #0078d4;
      padding-top: 1.1rem; padding-bottom: .3rem;
    }
    .infra-table tr.section-row:first-child td { padding-top: .1rem; }

    /* ── Bullet lists ── */
    .bullets { list-style: none; display: flex; flex-direction: column; gap: .7rem; }
    .bullets li {
      font-size: .865rem; color: #333; line-height: 1.55;
      padding-left: 1.15rem; position: relative;
    }
    .bullets li::before { content: "→"; position: absolute; left: 0; color: #0078d4; font-weight: 700; }
    .bullets li strong { color: #1a1a1a; }

    /* ── Timeline ── */
    .timeline { display: flex; flex-direction: column; gap: 0; }
    .tl-item {
      display: grid;
      grid-template-columns: 3.5rem 1fr;
      gap: 0 1rem;
      position: relative;
    }
    .tl-item:not(:last-child) .tl-line { display: block; }
    .tl-badge-col {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .tl-badge {
      width: 2rem; height: 2rem;
      border-radius: 50%;
      background: #0078d4;
      color: #fff;
      font-size: .7rem;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      z-index: 1;
    }
    .tl-line {
      width: 2px;
      flex: 1;
      background: #dde8f5;
      margin: .25rem 0;
      min-height: .75rem;
    }
    .tl-body { padding-bottom: 1.1rem; }
    .tl-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: #0078d4; }
    .tl-title { font-size: .9rem; font-weight: 600; color: #1a1a1a; margin: .15rem 0 .3rem; }
    .tl-desc { font-size: .82rem; color: #444; line-height: 1.5; }
    .tl-item:last-child .tl-body { padding-bottom: 0; }

    /* ── Tag chips ── */
    .tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-top: .75rem; }
    .tag {
      font-size: .68rem; font-weight: 600; letter-spacing: .04em;
      background: #e8f1fb; color: #005ea2;
      border-radius: 99px;
      padding: .2rem .6rem;
    }

    /* ── Mono ── */
    .mono { font-family: "Cascadia Code", "Fira Code", "Courier New", monospace; font-size: .77rem; word-break: break-all; }
    code {
      font-family: "Cascadia Code", "Fira Code", "Courier New", monospace;
      font-size: .82em;
      background: #f0f4fa;
      padding: .1em .35em;
      border-radius: 4px;
      color: #005ea2;
    }

    /* ── Code blocks ── */
    .code-section { display: flex; flex-direction: column; gap: 1.1rem; }
    .code-block { background: #0d1117; border-radius: 8px; overflow: hidden; }
    .code-label {
      font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      color: #7d8590; background: #161b22; padding: .4rem .9rem;
      border-bottom: 1px solid #21262d;
    }
    .code-block pre {
      margin: 0; padding: .9rem 1rem;
      font-family: "Cascadia Code", "Fira Code", "Courier New", monospace;
      font-size: .78rem; line-height: 1.6;
      color: #e6edf3; overflow-x: auto;
    }
    .c  { color: #8b949e; }  /* comment */
    .k  { color: #ff7b72; }  /* keyword */
    .s  { color: #a5d6ff; }  /* string */
    .v  { color: #79c0ff; }  /* variable/resource name */
    .f  { color: #d2a8ff; }  /* function/block */
    .n  { color: #ffa657; }  /* number/value */

    /* ── Note box ── */
    .note {
      background: #f4f8fd;
      border-left: 3px solid #0078d4;
      border-radius: 0 6px 6px 0;
      padding: .6rem .9rem;
      font-size: .82rem;
      color: #444;
      line-height: 1.5;
      margin-top: .9rem;
    }
  </style>
</head>
<body>
  <header>
    <div class="hd-left">
      <div>
        <div class="hd-title">Cloud Systems — Azure IaC Deployment</div>
        <div class="hd-sub">MITS 5760 &nbsp;·&nbsp; Spring 2026 &nbsp;·&nbsp; {{ app_domain }}</div>
      </div>
      <div class="status-pill"><span class="status-dot"></span>Operational</div>
    </div>
    <div class="hd-clocks">
      <span id="clock-utc">UTC —:—:—</span>
      <span id="clock-local"></span>
    </div>
  </header>

  <main>

    <!-- Overview stats -->
    <div class="card">
      <div class="card-title">Project Overview</div>
      <div class="stat-row">
        <div class="stat"><div class="stat-num">2</div><div class="stat-label">Linux VMs</div></div>
        <div class="stat"><div class="stat-num">1</div><div class="stat-label">VNet / 2 Subnets</div></div>
        <div class="stat"><div class="stat-num">TLS</div><div class="stat-label">Let's Encrypt</div></div>
        <div class="stat"><div class="stat-num">IaC</div><div class="stat-label">100% Automated</div></div>
        <div class="stat"><div class="stat-num">MCP</div><div class="stat-label">AI Interface</div></div>
        <div class="stat"><div class="stat-num">ARM</div><div class="stat-label">Ampere v8 VMs</div></div>
      </div>
      <p style="font-size:.875rem;color:#333;line-height:1.6;margin-top:1rem;">
        A fully automated, two-VM cloud deployment on Microsoft Azure. Infrastructure is defined entirely
        in <strong>Terraform</strong> and configured entirely by <strong>Ansible</strong>: a single
        <code>terraform apply</code> builds the network, VMs, Key Vault, and monitoring stack; a single
        <code>ansible-playbook</code> installs and hardens every service. No manual steps, no SSH
        one-liners, no configuration drift.
      </p>
    </div>

    <!-- Infra table + Security -->
    <div class="row">

      <div class="card">
        <div class="card-title">Infrastructure</div>
        <table class="infra-table">
          <tr class="section-row"><td colspan="2">Host</td></tr>
          <tr class="data"><td>Domain</td><td>{{ app_domain }}</td></tr>
          <tr class="data"><td>Region</td><td>Azure South Central US</td></tr>
          <tr class="data"><td>Protocol</td><td>HTTP/2 · TLS 1.2 / 1.3</td></tr>
          <tr class="data"><td>Certificate</td><td>Let's Encrypt (auto-renew)</td></tr>

          <tr class="section-row"><td colspan="2">Virtual Machines</td></tr>
          <tr class="data"><td>App VM</td><td>Standard_B2pts_v2 · ARM64</td></tr>
          <tr class="data"><td>DB VM</td><td>Standard_B2pts_v2 · ARM64</td></tr>
          <tr class="data"><td>OS</td><td>Ubuntu 24.04 LTS (arm64)</td></tr>
          <tr class="data"><td>Auth</td><td>SSH key only — no passwords</td></tr>

          <tr class="section-row"><td colspan="2">Network</td></tr>
          <tr class="data"><td>VNet</td><td>10.0.0.0/16</td></tr>
          <tr class="data"><td>App subnet</td><td>10.0.1.0/24 (public IP)</td></tr>
          <tr class="data"><td>DB subnet</td><td>10.0.2.0/24 (no public IP)</td></tr>
          <tr class="data"><td>DB port 3306</td><td>App subnet only (NSG rule)</td></tr>
          <tr class="data"><td>DB SSH</td><td>App subnet only (bastion pattern)</td></tr>

          <tr class="section-row"><td colspan="2">Automation Stack</td></tr>
          <tr class="data"><td>Provisioning</td><td>Terraform</td></tr>
          <tr class="data"><td>Configuration</td><td>Ansible</td></tr>
          <tr class="data"><td>Secret encryption</td><td>Ansible Vault</td></tr>
          <tr class="data"><td>Vault password</td><td>Azure Key Vault (runtime fetch)</td></tr>
          <tr class="data"><td>Terraform state</td><td>Azure Blob Storage (shared, locked)</td></tr>
          <tr class="data"><td>Monitoring</td><td>Azure Monitor + email alerts</td></tr>
          <tr class="data"><td>AI interface</td><td>MCP over SSE</td></tr>
        </table>
      </div>

      <div class="card">
        <div class="card-title">Security Hardening</div>
        <ul class="bullets">
          <li><strong>SSH key-only authentication.</strong> Password auth is disabled on both VMs. The DB VM has no public IP — SSH in requires tunneling through the app VM.</li>
          <li><strong>fail2ban</strong> is deployed on both VMs. After 5 failed SSH attempts in 10 minutes, the source IP is banned for 1 hour.</li>
          <li><strong>Unattended security upgrades</strong> run automatically on both VMs, pulling patches from the Ubuntu security repository without manual intervention.</li>
          <li><strong>MariaDB hardened at deploy time:</strong> anonymous users removed, test database dropped, remote root login disabled. Equivalent to running <code>mysql_secure_installation</code> fully scripted.</li>
          <li><strong>MariaDB bound to the DB subnet interface only</strong> — even within the VNet, the database process does not listen on the public-facing NIC.</li>
          <li><strong>NSG rules are the enforcement layer.</strong> The DB NSG allows port 3306 from <code>10.0.1.0/24</code> only. No internet path to the database exists at the network level.</li>
          <li><strong>Ansible Vault</strong> encrypts all secrets (DB credentials, etc.) at rest. The decryption password is stored in Azure Key Vault and fetched at runtime via <code>vault_pass.sh</code> — it never touches disk on the operator's machine.</li>
          <li><strong>Azure Monitor</strong> alerts on sustained CPU &gt; 85% for 5 minutes. Alerts go to email via an Action Group.</li>
        </ul>
        <div class="note">
          The DB VM's isolation is enforced at two independent layers: Azure NSG rules (network-level) and MariaDB's own bind-address configuration (process-level). Either layer alone would block external access; both together are the minimum responsible baseline.
        </div>
      </div>

    </div>

    <!-- Development iterations -->
    <div class="card">
      <div class="card-title">Development — How It Evolved</div>
      <div class="timeline">

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">1</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 1</div>
            <div class="tl-title">Terraform + Ansible scaffolding — single VM, HTTP only</div>
            <div class="tl-desc">
              Started with one VM, one subnet, no TLS. Terraform provisions the VM and public IP; Ansible installs
              nginx and drops a static page. The goal was proving the IaC pipeline end-to-end before adding complexity.
              Manually SSHing into a cloud VM to make changes was the comparison point — every subsequent addition had
              to remain fully automated to be worth keeping.
            </div>
            <div class="tags"><span class="tag">Terraform</span><span class="tag">Ansible</span><span class="tag">nginx</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">2</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 2</div>
            <div class="tl-title">Two-tier network — separate app and DB subnets, MariaDB</div>
            <div class="tl-desc">
              Split into two VMs across two subnets. The DB VM gets no public IP; only the app subnet can reach
              port 3306. Ansible now runs two separate playbooks — one per host group. This is where Terraform's
              <code>local_file</code> resource became essential: it writes the live public IP directly into
              Ansible's inventory and group vars on every apply, so re-running the playbook after an IP change
              always reaches the right host.
            </div>
            <div class="tags"><span class="tag">Two-tier</span><span class="tag">NSG</span><span class="tag">MariaDB</span><span class="tag">Inventory automation</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">3</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 3</div>
            <div class="tl-title">TLS + secrets management — Let's Encrypt, Ansible Vault, remote state</div>
            <div class="tl-desc">
              The chicken-and-egg problem with certbot: nginx must be listening on port 80 to complete the
              ACME challenge, but the final nginx config references the TLS cert. Solved by deploying an
              HTTP-only config first (with <code>when: not cert_stat.stat.exists</code>), running certbot,
              then deploying the SSL config. Secrets moved into Ansible Vault. Terraform state moved to
              Azure Blob Storage so it's never on a local machine and multiple operators can share it safely.
              Used <code>nip.io</code> to turn the static public IP into a resolvable domain without buying one.
            </div>
            <div class="tags"><span class="tag">Let's Encrypt</span><span class="tag">Ansible Vault</span><span class="tag">Azure Blob</span><span class="tag">nip.io</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">4</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 4</div>
            <div class="tl-title">Hardening — fail2ban, unattended-upgrades, MariaDB lockdown, ARM64 VMs</div>
            <div class="tl-desc">
              Added operational security: fail2ban on both VMs for SSH brute-force protection, unattended-upgrades
              for automated patch management, and full MariaDB hardening scripted through Ansible's
              <code>mysql_user</code> / <code>mysql_db</code> modules. Switched from Standard_B2s (x86) to
              <strong>Standard_B2pts_v2</strong> (Ampere ARM64) — same performance tier, lower cost, and Ubuntu
              24.04 has first-class ARM64 support. All Ansible tasks are idempotent; re-running the playbook
              on an already-hardened server is a no-op.
            </div>
            <div class="tags"><span class="tag">fail2ban</span><span class="tag">Unattended-upgrades</span><span class="tag">ARM64</span><span class="tag">MariaDB hardening</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">5</div>
            <div class="tl-line"></div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 5</div>
            <div class="tl-title">Azure Key Vault — passwordless Ansible Vault at runtime</div>
            <div class="tl-desc">
              Previously, decrypting Ansible Vault required typing (or storing) the vault password locally.
              Replaced this with <code>vault_pass.sh</code>: a script that calls <code>az keyvault secret show</code>
              and prints the password to stdout. Ansible's <code>--vault-password-file</code> flag accepts
              any executable, so it calls the script at runtime. The vault password is stored only in
              Azure Key Vault, protected by Azure RBAC. Terraform provisions the Key Vault and access policy
              as part of the same apply.
            </div>
            <div class="tags"><span class="tag">Azure Key Vault</span><span class="tag">RBAC</span><span class="tag">Passwordless</span></div>
          </div>
        </div>

        <div class="tl-item">
          <div class="tl-badge-col">
            <div class="tl-badge">6</div>
          </div>
          <div class="tl-body">
            <div class="tl-label">Iteration 6</div>
            <div class="tl-title">MCP servers + Azure Monitor — AI-accessible infrastructure and alerting</div>
            <div class="tl-desc">
              Added two <strong>Model Context Protocol (MCP)</strong> servers: one on the app VM exposing
              infrastructure tools, one on the DB VM exposing database query tools. Both run as systemd
              services (Python/FastMCP + uvicorn), proxied through nginx over Server-Sent Events. This lets
              Claude Code connect directly to the live deployment and query real infrastructure state —
              the <em>cloud-infra</em> MCP server visible in Claude Code's sidebar is this deployment.
              Also added Azure Monitor metric alerts: CPU &gt; 85% sustained for 5 minutes triggers an
              email via Action Group.
            </div>
            <div class="tags"><span class="tag">MCP / SSE</span><span class="tag">FastMCP</span><span class="tag">systemd</span><span class="tag">Azure Monitor</span><span class="tag">Action Groups</span></div>
          </div>
        </div>

      </div>
    </div>

    <!-- MCP + Visitor -->
    <div class="row">

      <div class="card">
        <div class="card-title">MCP — AI Interface Layer</div>
        <p style="font-size:.875rem;color:#333;line-height:1.6;margin-bottom:.9rem;">
          The Model Context Protocol (MCP) is an open standard for giving AI assistants structured
          access to external tools and data. Two MCP servers run on this deployment:
        </p>
        <ul class="bullets">
          <li><strong>mcp-infra</strong> (app VM, port 8000) — exposes tools for querying live system metrics: uptime, load average, memory usage, disk, and nginx connection stats. Proxied by nginx at <code>/mcp/</code>.</li>
          <li><strong>mcp-db</strong> (DB VM, port 8001) — exposes tools for querying the MariaDB instance. Accessible only through the app VM; the DB VM has no public IP.</li>
        </ul>
        <div class="note">
          Both servers speak the MCP protocol over HTTP Server-Sent Events (SSE). Claude Code's
          <em>cloud-infra</em> server entry points at this deployment — the system info and nginx stats
          shown in Claude Code come from this live VM in real time.
        </div>
        <div class="tags" style="margin-top:.9rem;">
          <span class="tag">MCP / SSE</span>
          <span class="tag">FastMCP</span>
          <span class="tag">uvicorn</span>
          <span class="tag">nginx proxy</span>
          <span class="tag">systemd services</span>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Your Connection</div>
        <table class="vis-table">
          <tr><td>Browser</td><td id="v-browser"></td></tr>
          <tr><td>OS</td><td id="v-os"></td></tr>
          <tr><td>Language</td><td id="v-lang"></td></tr>
          <tr><td>Screen</td><td id="v-screen"></td></tr>
          <tr><td>CPU threads</td><td id="v-cpu"></td></tr>
          <tr><td>Cookies</td><td id="v-cookies"></td></tr>
          <tr><td>Page load</td><td id="v-load"></td></tr>
          <tr><td>User agent</td><td id="v-ua" class="mono"></td></tr>
        </table>
      </div>

    </div>

    <!-- Commands -->
    <div class="card">
      <div class="card-title">Deployment — Two Commands</div>
      <div class="code-section">
        <div class="code-block">
          <div class="code-label">1 — Provision infrastructure (Terraform)</div>
          <pre><span class="c"># Creates VNet, subnets, NSGs, VMs, Key Vault, Monitor alerts,</span>
<span class="c"># and writes inventory.ini + group_vars with the live public IP.</span>
terraform apply -auto-approve</pre>
        </div>
        <div class="code-block">
          <div class="code-label">2 — Configure everything (Ansible)</div>
          <pre><span class="c"># Installs and hardens both VMs: nginx, TLS, fail2ban,</span>
<span class="c"># unattended-upgrades, MariaDB, MCP servers — all idempotent.</span>
<span class="c"># Vault password fetched from Azure Key Vault at runtime (vault_pass.sh).</span>
ansible-playbook setup_app.yml setup_db.yml -i inventory.ini</pre>
        </div>
      </div>
    </div>

    <!-- Config highlights -->
    <div class="row">

      <div class="card">
        <div class="card-title">Terraform — Key Blocks</div>
        <div class="code-section">

          <div class="code-block">
            <div class="code-label">NSG: DB only reachable from app subnet</div>
            <pre><span class="f">resource</span> <span class="s">"azurerm_network_security_group"</span> <span class="v">"db_nsg"</span> {
  <span class="c"># No public IP on DB VM + NSG = two independent</span>
  <span class="c"># enforcement layers blocking internet access.</span>

  <span class="f">security_rule</span> {
    name                  = <span class="s">"AllowMySQL"</span>
    priority              = <span class="n">100</span>
    direction             = <span class="s">"Inbound"</span>
    access                = <span class="s">"Allow"</span>
    destination_port      = <span class="s">"3306"</span>
    <span class="c"># App subnet CIDR only — nothing else can reach MariaDB</span>
    source_address_prefix = <span class="s">"10.0.1.0/24"</span>
  }
}</pre>
          </div>

          <div class="code-block">
            <div class="code-label">Key Vault — Ansible Vault password at rest</div>
            <pre><span class="f">resource</span> <span class="s">"azurerm_key_vault"</span> <span class="v">"kv"</span> {
  name      = <span class="s">"cloud-v3-kv"</span>
  tenant_id = <span class="f">data.azurerm_client_config.current</span>.tenant_id
  sku_name  = <span class="s">"standard"</span>
  <span class="c"># Vault password stored here; fetched at runtime</span>
  <span class="c"># by vault_pass.sh — never touches disk locally.</span>
}

<span class="c"># Terraform writes the live IP into Ansible's inventory</span>
<span class="c"># on every apply — no manual IP hunting after redeploy.</span>
<span class="f">resource</span> <span class="s">"local_file"</span> <span class="v">"ansible_vars"</span> {
  content  = <span class="s">"app_domain: \"</span><span class="n">${azurerm_public_ip.app_pip.ip_address}</span><span class="s">.nip.io\""</span>
  filename = <span class="s">"group_vars/all/terraform_outputs.yml"</span>
}</pre>
          </div>

        </div>
      </div>

      <div class="card">
        <div class="card-title">Ansible — Key Tasks</div>
        <div class="code-section">

          <div class="code-block">
            <div class="code-label">Certbot — HTTP config first, then TLS</div>
            <pre><span class="c"># Chicken-and-egg: certbot needs port 80 open to</span>
<span class="c"># validate the domain, but the final nginx config</span>
<span class="c"># references the cert that doesn't exist yet.</span>
- <span class="k">name</span>: Deploy HTTP-only nginx config
  <span class="k">template</span>:
    src: nginx.conf.j2
    dest: /etc/nginx/nginx.conf
  <span class="k">when</span>: not cert_stat.stat.exists  <span class="c"># skip if cert already exists</span>

- <span class="k">name</span>: Obtain SSL certificate
  <span class="k">command</span>: >
    certbot certonly --webroot -w /var/www/html
    -d {{ app_domain }} --non-interactive
  args:
    creates: /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem

- <span class="k">name</span>: Deploy HTTPS nginx config  <span class="c"># now the cert exists</span>
  <span class="k">template</span>:
    src: nginx_ssl.conf.j2
    dest: /etc/nginx/nginx.conf</pre>
          </div>

          <div class="code-block">
            <div class="code-label">MariaDB hardening (scripted secure_installation)</div>
            <pre"><span class="c"># Equivalent to running mysql_secure_installation,</span>
<span class="c"># but fully automated and idempotent.</span>
- <span class="k">name</span>: Remove anonymous users
  <span class="k">mysql_user</span>:
    name: <span class="s">''</span>
    host_all: yes
    state: absent

- <span class="k">name</span>: Disallow remote root login
  <span class="k">mysql_user</span>:
    name: root
    host: <span class="s">'%'</span>
    state: absent

- <span class="k">name</span>: Bind MariaDB to internal subnet only
  <span class="k">copy</span>:
    dest: /etc/mysql/mariadb.conf.d/99-bind.cnf
    content: |
      [mysqld]
      bind-address = {{ db_bind_address }}</pre>
          </div>

        </div>
      </div>

    </div>

  </main>

  <script src="/session.js"></script>
</body>
</html>
