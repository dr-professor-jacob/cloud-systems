<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jacob Rickey</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Segoe UI", system-ui, sans-serif;
      background: #eef2f7;
      color: #1a1a1a;
      min-height: 100vh;
    }

    header {
      background: linear-gradient(135deg, #005ea2 0%, #0078d4 100%);
      color: #fff;
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .hd-title { font-size: 1.15rem; font-weight: 700; letter-spacing: .02em; }
    .hd-sub   { font-size: .75rem; opacity: .75; margin-top: .2rem; }
    .hd-links { display: flex; flex-wrap: wrap; gap: .45rem; }
    .hd-link  {
      font-size: .75rem; font-weight: 600;
      color: rgba(255,255,255,.85); border: 1px solid rgba(255,255,255,.3);
      border-radius: 5px; padding: .25rem .65rem;
      text-decoration: none; transition: background .12s;
    }
    .hd-link:hover { background: rgba(255,255,255,.15); }

    main {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1.5rem 3rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    @media (max-width: 760px) {
      .row { grid-template-columns: 1fr; }
    }

    .card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(0,0,0,.06), 0 4px 14px rgba(0,0,0,.06);
      padding: 1.4rem 1.5rem;
    }
    .card-title {
      font-size: .68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .1em; color: #0078d4;
      margin-bottom: .9rem; padding-bottom: .6rem;
      border-bottom: 1px solid #f0f0f0;
    }

    .tags { display: flex; flex-wrap: wrap; gap: .4rem; }
    .tag {
      font-size: .68rem; font-weight: 600; letter-spacing: .04em;
      background: #e8f1fb; color: #005ea2;
      border-radius: 99px; padding: .2rem .6rem;
    }

    .link-btn {
      display: inline-flex; align-items: center; gap: .3rem;
      font-size: .78rem; font-weight: 600;
      color: #0078d4; border: 1px solid #c7d9f8;
      background: #f0f6ff; border-radius: 6px;
      padding: .3rem .8rem; text-decoration: none;
      transition: background .12s; white-space: nowrap;
    }
    .link-btn:hover { background: #ddeeff; }

    .proj-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }
    .proj-card {
      border: 1px solid #e6edf5; border-radius: 8px;
      padding: 1rem 1.1rem;
      display: flex; flex-direction: column; gap: .45rem;
    }
    .proj-card-title { font-size: .9rem; font-weight: 600; color: #1a1a1a; }
    .proj-card-desc  { font-size: .82rem; color: #555; line-height: 1.5; flex: 1; }
    .status-badge {
      font-size: .62rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
      padding: .15rem .55rem; border-radius: 99px; white-space: nowrap; flex-shrink: 0;
    }
    .status-active { background: #e6f9ee; color: #1a7a3a; }
    .status-done   { background: #f0f4fa; color: #5a6a80; }

    .course-list { display: flex; flex-direction: column; gap: .55rem; }
    .course-item {
      display: flex; align-items: baseline;
      justify-content: space-between; gap: .5rem;
    }
    .course-name { font-size: .85rem; font-weight: 500; color: #1a1a1a; }
    .course-sub  { font-size: .75rem; color: #888; white-space: nowrap; }
  </style>
</head>
