user www-data;
worker_processes auto;
pid /run/nginx.pid;

events {
    worker_connections 768;
    multi_accept on;
}

http {
    server_tokens off;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    map_hash_bucket_size 128;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # SSL session cache
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 8.8.4.4 valid=300s;
    resolver_timeout 5s;

    # Rate limiting
    limit_req_zone $binary_remote_addr zone=default:10m rate=10r/s;

    # MCP bearer token check
    map $http_authorization $mcp_auth_ok {
        "Bearer {{ mcp_api_key }}" 1;
        default                    0;
    }

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log;

    # Redirect HTTP to HTTPS
    server {
        listen 80 default_server;
        server_name {{ app_domain }} _;

        # nginx metrics - localhost only (used by MCP server)
        location /nginx_status {
            stub_status on;
            access_log  off;
            allow       127.0.0.1;
            deny        all;
        }

        location / {
            return 301 https://$host$request_uri;
        }
    }

    server {
        listen 443 ssl http2;
        server_name {{ app_domain }};

        ssl_certificate /etc/letsencrypt/live/{{ app_domain }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/{{ app_domain }}/privkey.pem;
        ssl_protocols TLSv1.3;
        ssl_prefer_server_ciphers off;
        ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

        # Security headers
        add_header Strict-Transport-Security    "max-age=31536000; includeSubDomains; preload"                        always;
        add_header X-Frame-Options              "SAMEORIGIN"                                                          always;
        add_header X-Content-Type-Options       "nosniff"                                                             always;
        add_header Referrer-Policy              "strict-origin-when-cross-origin"                                     always;
        add_header Content-Security-Policy      "default-src 'self'; style-src 'self' 'unsafe-inline'; frame-ancestors 'self'" always;
        add_header Permissions-Policy           "geolocation=(), microphone=(), camera=(), payment=(), usb=()"        always;
        add_header Cross-Origin-Opener-Policy   "same-origin"                                                         always;

        # Rate limiting
        limit_req zone=default burst=20 nodelay;

        access_log /var/log/nginx/app_access.log;
        error_log  /var/log/nginx/app_error.log;

        root /var/www/html;
        index index.html;

        location / {
            try_files $uri $uri/ =404;
        }

        # nginx metrics - localhost only (used by MCP server)
        location /nginx_status {
            stub_status on;
            access_log  off;
            allow       127.0.0.1;
            deny        all;
        }

        # MCP OAuth discovery - return JSON 404 so clients skip OAuth gracefully
        location = /.well-known/oauth-authorization-server {
            default_type application/json;
            return 404 '{"error":"not_found"}';
        }

        # MCP infrastructure server - Streamable HTTP proxy
        location /mcp {
            if ($mcp_auth_ok = 0) { return 401; }
            proxy_pass         http://127.0.0.1:8000/mcp;
            proxy_http_version 1.1;
            proxy_set_header   Host         127.0.0.1:8000;
            proxy_set_header   X-Real-IP    $remote_addr;
            proxy_buffering    off;
            proxy_cache        off;
            proxy_read_timeout 3600s;
        }

        # Visitor question demo - rate-limited Claude endpoint
        location = /ask {
            proxy_pass         http://127.0.0.1:8002/ask;
            proxy_http_version 1.1;
            proxy_set_header   Host         $host;
            proxy_set_header   X-Real-IP    $remote_addr;
            proxy_read_timeout 30s;
        }
    }

    # Dummy server for TeamSpeak subdomain to handle HSTS.
    # Prevents browser SSL errors when navigating to ts.jrickey.cc.
    server {
        listen 443 ssl http2;
        server_name ts.{{ app_domain }};

        ssl_certificate /etc/ssl/certs/ssl-cert-snakeoil.pem;
        ssl_certificate_key /etc/ssl/private/ssl-cert-snakeoil.key;

        return 404;
    }
}
